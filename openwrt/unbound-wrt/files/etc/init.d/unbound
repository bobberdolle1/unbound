#!/bin/sh /etc/rc.common
#
# /etc/init.d/unbound - procd init script for nfqws daemon
#
# Copyright (C) 2024 Unbound-WRT Project
#

START=95
STOP=10
USE_PROCD=1

EXE=/usr/bin/nfqws
CONFIG_FILE=/etc/config/unbound

# Strategy-to-nfqws-args mapping
get_strategy_args() {
	local strategy="$1"
	case "$strategy" in
		multidisorder)
			echo "--wf-l3=ndisorder --wf-tcp=80,443 --wsize=3:7"
			;;
		split-tls)
			echo "--wf-l3=split --wf-tcp=443 --wsize=1:2"
			;;
		fake-ping)
			echo "--wf-l3=fake --wf-tcp=80,443 --fake=0.3"
			;;
		disorder-fake)
			echo "--wf-l3=ndisorder,fake --wf-tcp=80,443 --wsize=3:7 --fake=0.3"
			;;
		*)
			echo "--wf-l3=ndisorder --wf-tcp=80,443 --wsize=3:7"
			;;
	esac
}

start_service() {
	local enabled strategy
	config_load unbound
	config_get enabled general enabled
	config_get strategy general strategy

	[ "$enabled" = "1" ] || return 0
	[ -x "$EXE" ] || { echo "nfqws not found at $EXE"; return 1; }

	local args
	args=$(get_strategy_args "${strategy:-multidisorder}")
	args="$args --queue-num=200"

	procd_open_instance
	procd_set_param command $EXE
	for arg_item in $args; do
		procd_append_param command "$arg_item"
	done
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param pidfile /var/run/nfqws.pid
	procd_close_instance

	/etc/init.d/firewall reload
}

stop_service() {
	procd_kill "$NAME" 2>/dev/null
	/etc/init.d/firewall reload
}

restart_service() {
	stop_service
	sleep 1
	start_service
}

reload_service() {
	restart_service
}
