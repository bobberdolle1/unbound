# Environment Variables Template
# Copy this file to .env.local and fill in the values

# Extension ID for native messaging (get this after loading the extension)
VITE_EXTENSION_ID=your-extension-id-here

# Native messaging host name
VITE_NATIVE_HOST_NAME=com.unbound.desktop

# Default proxy configuration (for standalone mode)
VITE_DEFAULT_PROXY_HOST=
VITE_DEFAULT_PROXY_PORT=
VITE_DEFAULT_PROXY_PROTOCOL=https
