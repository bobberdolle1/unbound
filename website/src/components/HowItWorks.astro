  font-size: 2rem;
  font-weight: 900;
  min-width: 60px;
  font-family: 'JetBrains Mono', monospace;
  transition: all 0.3s ease;
}

.step-content h3 {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  transition: all 0.3s ease;
}

