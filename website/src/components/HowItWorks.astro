  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 1.5rem;
  transition: all 0.3s ease;
}

.section-title {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 800;
  margin-bottom: 1rem;
  letter-spacing: -1px;
  transition: all 0.3s ease;
}

.section-desc {
  font-size: 1.1rem;
  max-width: 600px;
  margin: 0 auto;
  transition: all 0.3s ease;
}

.steps {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.step {
  display: flex;
  gap: 2rem;
  align-items: flex-start;
  padding: 2rem;
  border-radius: 16px;
  transition: all 0.3s ease;
}

.step:hover {
  transform: translateY(-2px);
}

