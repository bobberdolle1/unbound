<footer class="footer card-aura">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <a href="#" class="footer-logo text-primary-aura">
          <span class="logo-icon">⚡</span>
          <span class="logo-text">UNBOUND</span>
        </a>
        <p class="text-secondary-aura">Бесплатный обход DPI с открытым исходным кодом. Разработано сообществом. Лицензия MIT.</p>
      </div>
      <div class="footer-links">
        <div class="footer-column">
          <h4 class="text-primary-aura">Проект</h4>
          <a href="https://github.com/bobberdolle1/unbound" target="_blank" rel="noopener" class="text-secondary-aura">GitHub</a>
          <a href="https://github.com/bobberdolle1/unbound/releases" target="_blank" rel="noopener" class="text-secondary-aura">Релизы</a>
          <a href="https://github.com/bobberdolle1/unbound/issues" target="_blank" rel="noopener" class="text-secondary-aura">Тикеты (Issues)</a>
        </div>
        <div class="footer-column">
          <h4 class="text-primary-aura">Технологии</h4>
          <a href="https://github.com/bol-van/zapret" target="_blank" rel="noopener" class="text-secondary-aura">Движок Zapret</a>
          <a href="https://wails.io" target="_blank" rel="noopener" class="text-secondary-aura">Фреймворк Wails</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="text-secondary-aura">&copy; 2026 Проект Unbound. Распространяется под лицензией <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener" class="text-primary-aura">MIT</a>.</p>
    </div>
  </div>
</footer>

<style>
.footer {
  padding: 6rem 2rem 3rem;
  margin-top: 4rem;
  border-bottom: none;
  border-left: none;
  border-right: none;
  border-radius: 0;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
}

.footer-content {
  display: flex;
  justify-content: space-between;
  gap: 3rem;
  margin-bottom: 4rem;
}

.footer-brand {
  max-width: 320px;
}

.footer-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  font-weight: 800;
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
}

.logo-text {
  letter-spacing: 2px;
}

.footer-brand p {
  font-size: 1rem;
  line-height: 1.6;
}

.footer-links {
  display: flex;
  gap: 5rem;
}

.footer-column h4 {
  font-size: 0.85rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 1.5rem;
}

.footer-column a {
  display: block;
  font-size: 1rem;
  margin-bottom: 0.75rem;
  text-decoration: none;
  transition: all 0.2s ease;
}

.footer-column a:hover {
  transform: translateX(4px);
}

.footer-bottom {
  padding-top: 3rem;
  border-top: 1px solid var(--border-color);
  text-align: center;
}

.footer-bottom p {
  font-size: 0.9rem;
}

.footer-bottom a {
  text-decoration: none;
  font-weight: 600;
}

@media (max-width: 768px) {
  .footer-content {
    flex-direction: column;
    text-align: center;
  }
  .footer-logo {
    justify-content: center;
  }
  .footer-links {
    justify-content: center;
    gap: 3rem;
  }
}
</style>
