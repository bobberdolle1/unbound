---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-badge card-aura">
      <span class="badge-dot"></span>
      <span>v2.5.0 — Aura Design Edition</span>
    </div>
    <h1 class="hero-title">
      Обход<br />
      <span class="gradient-text">DPI-блокировок</span>
    </h1>
    <p class="hero-subtitle text-secondary-aura">
      Бесплатная программа с открытым кодом для разблокировки YouTube, Discord, Instagram, Twitter/X.
      Работает на <strong>Windows, Android, Linux, iOS, OpenWrt</strong> — <strong>без потери скорости</strong>.
    </p>
    <div class="hero-actions">
      <a href="#download" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Скачать бесплатно
      </a>
      <a href="#how-it-works" class="btn btn-secondary card-aura">
        Как это работает
      </a>
    </div>
    <div class="hero-stats card-aura">
      <div class="stat">
        <span class="stat-value">70+</span>
        <span class="stat-label text-secondary-aura">Профилей</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">0%</span>
        <span class="stat-label text-secondary-aura">Потери</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">6</span>
        <span class="stat-label text-secondary-aura">Платформ</span>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 8rem 2rem 4rem;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(circle at 50% 50%, var(--bg-secondary) 0%, var(--bg-primary) 100%);
  opacity: 0.8;
  z-index: -1;
}

.hero-content {
  max-width: 800px;
  position: relative;
  z-index: 100;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1.25rem;
  font-size: 0.85rem;
  margin-bottom: 2rem;
}

.badge-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 10px var(--accent);
  animation: pulse-dot 2s infinite;
}

@keyframes pulse-dot {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.5); opacity: 0.5; }
}

.hero-title {
  font-size: clamp(3rem, 8vw, 5.5rem);
  font-weight: 900;
  line-height: 1.05;
  margin-bottom: 1.5rem;
  letter-spacing: -2px;
  color: var(--text-primary);
}

.gradient-text {
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-secondary) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: clamp(1rem, 2vw, 1.25rem);
  line-height: 1.7;
  margin-bottom: 2.5rem;
  max-width: 650px;
  margin-left: auto;
  margin-right: auto;
}

.hero-actions {
  display: flex;
  gap: 1.5rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 4rem;
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 2rem;
  font-weight: 600;
  color: var(--text-primary);
}

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3rem;
  padding: 2rem 4rem;
}

.stat-value {
  display: block;
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--text-primary);
  line-height: 1;
  margin-bottom: 0.5rem;
}

.stat-label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-weight: 700;
}

.stat-divider {
  width: 1px;
  height: 50px;
  background: var(--border-color);
}


.hero-scroll {
  position: absolute;
  bottom: 2rem;
  animation: bounce 2s infinite;
}

.hero-scroll a {
  transition: color 0.2s;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(8px); }
}

@media (max-width: 640px) {
  .hero-stats {
    flex-direction: column;
    gap: 1rem;
  }
  .stat-divider {
    width: 40px;
    height: 1px;
  }
}
</style>
